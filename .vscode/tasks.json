{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "release-push-main",
            "type": "shell",
            "command": "cd /workspaces/CVOPro && git add app/*.py app/templates/*.html run.py render.yaml requirements.txt .vscode/tasks.json && git commit -m \"chore: release update\" && git push origin main",
            "options": {
                "cwd": "/workspaces/CVOPro"
            },
            "problemMatcher": []
        },
        {
            "label": "deploy-trigger-empty-commit",
            "type": "shell",
            "command": "cd /workspaces/CVOPro && git commit --allow-empty -m \"chore: trigger render deploy\" && git push origin main",
            "options": {
                "cwd": "/workspaces/CVOPro"
            },
            "problemMatcher": []
        },
        {
            "label": "cleanup-remove-xls",
            "type": "shell",
            "command": "cd /workspaces/CVOPro && git rm -f app/6683111743950724219.xls && git add .vscode/tasks.json && git commit -m \"chore: remove accidental xls artifact and tighten release task\" && git push origin main",
            "options": {
                "cwd": "/workspaces/CVOPro"
            },
            "problemMatcher": []
        },
        {
            "label": "git-status-short",
            "type": "shell",
            "command": "cd /workspaces/CVOPro && git status --short --branch",
            "options": {
                "cwd": "/workspaces/CVOPro"
            },
            "problemMatcher": []
        },
        {
            "label": "push-hotfix-fast-poll",
            "type": "shell",
            "command": "cd /workspaces/CVOPro && git add app/leads_app.py app/templates/index.html && git commit -m \"fix: prevent poll UI pinwheel and speed manual poll\" && git push origin main",
            "options": {
                "cwd": "/workspaces/CVOPro"
            },
            "problemMatcher": []
        },
