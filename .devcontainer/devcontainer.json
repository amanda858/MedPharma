{
    "forwardPorts": [
        8000,
        5240
    ],
    "portsAttributes": {
        "8000": {
            "label": "Lab Lead Generator",
            "onAutoForward": "notify",
            "visibility": "public"
        },
        "5240": {
            "label": "Client Hub",
            "onAutoForward": "notify",
            "visibility": "public"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscodevim.vim",
                "github.vscode-github-actions",
                "GitHub.copilot-chat",
                "eamodio.gitlens",
                "ms-vscode.vscode-typescript-next",
                "bradlc.vscode-tailwindcss"
            ]
        }
    }
}